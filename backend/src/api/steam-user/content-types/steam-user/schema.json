      "target": "plugin::users-permissions.user"
    },
    "communityvisibilitystate": {
      "type": "integer"
    },
    "profilestate": {
      "type": "integer"
    },
    "entityTag": {
      "type": "string"
    },
    "steamApiCache": {
      "type": "json"
    },
    "steam_owned_games_sync_jobs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::steam-owned-games-sync-job.steam-owned-games-sync-job",
      "mappedBy": "steamUser"
    },
    "steamProfileSyncJobs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::steam-profile-sync-job.steam-profile-sync-job",
      "mappedBy": "steamUser"
    },
    "lastProfileSyncAt": {
      "type": "datetime"
    }
