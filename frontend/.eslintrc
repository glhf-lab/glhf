{
  "extends": ["next", "prettier"],
  "plugins": ["prettier"],
  "settings": {
    "next": {
      "rootDir": "frontend/"
    }
  },
  "rules": {
    "prettier/prettier": [
      "error",
      {
        "printWidth": 80,
        "singleQuote": false,
        "trailingComma": "es5",
        "semi": false,
        "tabWidth": 2
      }
    ]
  }
}
